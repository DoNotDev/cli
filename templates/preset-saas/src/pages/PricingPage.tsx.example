'use client';
// {{appName}} - Pricing Page

import {
  CreditCard,
  Check,
  Zap,
  Building2,
  Sparkles,
} from 'lucide-react';

import {
  Accordion,
  Badge,
  BADGE_VARIANT,
  Button,
  BUTTON_VARIANT,
  Card,
  CARD_VARIANT,
  Grid,
  HeroSection,
  List,
  Section,
  Stack,
  Text,
} from '@donotdev/components';
import { useTranslation } from '@donotdev/core';
import { PageContainer } from '@donotdev/ui';

import type { PageMeta } from '@donotdev/core';

export const NAMESPACE = 'pricing';

export const meta: PageMeta = {
  namespace: NAMESPACE,
  icon: <CreditCard />,
};

const plans = [
  {
    name: 'Free',
    icon: Sparkles,
    price: '$0',
    period: 'forever',
    description: 'Perfect for getting started and personal projects.',
    features: [
      '1 project',
      '500 monthly active users',
      'Community support',
      'Basic analytics',
      '1 GB storage',
      'Standard API access',
    ],
    cta: 'getStarted',
    variant: CARD_VARIANT.DEFAULT,
    buttonVariant: BUTTON_VARIANT.OUTLINE,
  },
  {
    name: 'Pro',
    icon: Zap,
    price: '$29',
    period: '/month',
    description: 'For growing teams that need more power and flexibility.',
    features: [
      'Unlimited projects',
      '10,000 monthly active users',
      'Priority email support',
      'Advanced analytics & reports',
      '50 GB storage',
      'Custom domain',
      'Team collaboration (up to 10)',
      'Webhook integrations',
      'API rate limit: 10k/min',
    ],
    cta: 'startTrial',
    variant: CARD_VARIANT.ACCENT,
    buttonVariant: BUTTON_VARIANT.PRIMARY,
    popular: true,
  },
  {
    name: 'Enterprise',
    icon: Building2,
    price: 'Custom',
    period: '',
    description: 'For organizations that need enterprise-grade features and support.',
    features: [
      'Everything in Pro',
      'Unlimited active users',
      'Dedicated account manager',
      'Custom analytics & dashboards',
      'Unlimited storage',
      'SSO & SAML authentication',
      'Unlimited team members',
      'SLA guarantee (99.99%)',
      'On-premise deployment option',
      'Custom integrations',
    ],
    cta: 'contactSales',
    variant: CARD_VARIANT.DEFAULT,
    buttonVariant: BUTTON_VARIANT.SECONDARY,
  },
];

const faqItems = [
  {
    title: 'Can I switch plans at any time?',
    content: 'Yes. You can upgrade or downgrade your plan at any time. Changes take effect immediately, and we prorate the billing accordingly.',
  },
  {
    title: 'Is there a free trial for the Pro plan?',
    content: 'Yes, the Pro plan comes with a 14-day free trial. No credit card required to start. You can explore all Pro features before committing.',
  },
  {
    title: 'What payment methods do you accept?',
    content: 'We accept all major credit cards (Visa, Mastercard, American Express), as well as PayPal and bank transfers for annual Enterprise plans.',
  },
  {
    title: 'What happens when I exceed my usage limits?',
    content: 'We will notify you when you reach 80% of your plan limits. If you exceed them, your service continues uninterrupted and we will suggest an upgrade. We never cut access without warning.',
  },
  {
    title: 'Do you offer discounts for annual billing?',
    content: 'Yes. Annual billing saves you 20% compared to monthly billing. Contact us for Enterprise annual pricing.',
  },
  {
    title: 'Can I cancel at any time?',
    content: 'Absolutely. There are no long-term contracts or cancellation fees. You can cancel your subscription at any time from your account settings.',
  },
];

export default function PricingPage() {
  const { t } = useTranslation(NAMESPACE);

  return (
    <PageContainer>
      <HeroSection
        badge={t('pricing.hero.badge', 'Pricing')}
        title={t('pricing.hero.title', 'Plans That Grow With You')}
        subtitle={t('pricing.hero.subtitle', 'Start free, scale as you grow. No hidden fees, no surprises.')}
      />

      <Section title={t('pricing.plans.title', 'Choose Your Plan')}>
        <Grid cols={[1, 1, 3, 3]} gap="medium">
          {plans.map((plan) => (
            <Card
              key={plan.name}
              variant={plan.variant}
              icon={plan.icon}
              title={
                <Stack direction="row" align="center" gap="tight">
                  <Text level="h4">{plan.name}</Text>
                  {plan.popular && (
                    <Badge variant={BADGE_VARIANT.ACCENT}>
                      {t('pricing.popular', 'Most Popular')}
                    </Badge>
                  )}
                </Stack>
              }
              subtitle={plan.description}
              content={
                <Stack gap="medium">
                  <Stack direction="row" align="end" gap="tight">
                    <Text level="h2">{plan.price}</Text>
                    {plan.period && (
                      <Text level="body" variant="muted">{plan.period}</Text>
                    )}
                  </Stack>
                  <List
                    items={plan.features}
                    icon={Check}
                    gap="tight"
                    density="compact"
                  />
                </Stack>
              }
              footer={
                <Button variant={plan.buttonVariant} fullWidth>
                  {plan.cta === 'getStarted' && t('pricing.cta.getStarted', 'Get Started Free')}
                  {plan.cta === 'startTrial' && t('pricing.cta.startTrial', 'Start 14-Day Trial')}
                  {plan.cta === 'contactSales' && t('pricing.cta.contactSales', 'Contact Sales')}
                </Button>
              }
            />
          ))}
        </Grid>
      </Section>

      <Section title={t('pricing.faq.title', 'Frequently Asked Questions')} tone="muted">
        <Accordion
          items={faqItems.map((item) => ({
            title: t(`pricing.faq.${item.title}`, item.title),
            content: (
              <Text level="body" variant="muted">
                {t(`pricing.faq.${item.title}.answer`, item.content)}
              </Text>
            ),
          }))}
          type="single"
          collapsible
        />
      </Section>
    </PageContainer>
  );
}
