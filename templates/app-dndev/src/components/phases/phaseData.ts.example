/**
 * @fileoverview WAI-WAY phase constants, types, and shared parsers
 *
 * Shared across PhasesPage, HomePage, and phase sub-components.
 */

import type { LucideIcon } from 'lucide-react';
import { Lightbulb, FileCode, Database, Layers, Settings, CheckCircle2, Loader2, Circle } from 'lucide-react';

// ============================================================================
// TYPES — Protocol v2
// ============================================================================

export interface PhaseData {
  status?: 'pending' | 'active' | 'completed';
  startedAt?: string;
  completedAt?: string;
  summary?: string;
  fileCount?: number;
}

export interface ProtocolData {
  version?: number;
  currentPhase: number;
  phaseName?: string;
  agent?: string;
  startedAt?: string;
  phases: Record<number, PhaseData>;
  lookedUpSymbols?: string[];
  pendingReview?: boolean;
  currentModule?: string;
  toolCallCounts?: Record<string, number>;
  completedPhases?: number[];
  lessonsRecorded?: number;
}

export const DEFAULT_PROTOCOL: ProtocolData = { currentPhase: -1, phases: {} };

// ============================================================================
// TYPES — Progress
// ============================================================================

export interface ProgressItem {
  text: string;
  checked: boolean;
  line: number;
}

export interface ProgressSection {
  title: string;
  items: ProgressItem[];
}

// ============================================================================
// TYPES — Lessons
// ============================================================================

export interface Lesson {
  id: number;
  content: string;
  tags: string[];
  confidence: number;
  isAntiPattern: boolean;
  addedAt: string | null;
  phase: string | null;
}

// ============================================================================
// TYPES — Captain's Log
// ============================================================================

export interface CaptainLogSession {
  id: number;
  date: string;
  phase: number;
  phase_name: string;
  module?: string;
  started_at: string;
  completed_at: string;
  outcome: string;
  files_touched: number;
  symbols_used: number;
  tool_calls: Record<string, number>;
  lessons_recorded: number;
  lessons_scored?: { helpful: number; harmful: number };
  validation: string;
}

export interface CaptainLogData {
  project?: string;
  started?: string;
  sessions: CaptainLogSession[];
}

