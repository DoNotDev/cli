import type { ComponentType, ReactNode } from 'react';
import type { CSSFamily, PropType } from './ComponentsData';

/**
 * Extract variant values from VARIANT constant object
 * Converts { DEFAULT: 'default', PRIMARY: 'primary' } to ['default', 'primary']
 */
function getVariantValues<T extends Record<string, string>>(
  variantObj: T
): string[] {
  return Object.values(variantObj);
}

export interface ComponentConfig {
  id: string;
  name: string;
  component: ComponentType<any>;
  cssFamily: CSSFamily;
  variants: {
    variant?: string[];
    size?: string[];
    shadow?: string[];
    radius?: string[];
    tone?: string[];
    type?: string[];
    side?: string[];
    mode?: string[];
  };
  propTypes?: PropType[];
  stateType?:
    | 'controlled-value'
    | 'controlled-checked'
    | 'controlled-pressed'
    | 'controlled-range'
    | 'controlled-date'
    | 'controlled-dates'
    | 'controlled-date-range'
    | 'custom';
  defaultStateValue?: any;
  renderMode?: 'default' | 'overlay' | 'modal' | 'tabs-generator';
  supportsCommonProps: {
    title?: boolean;
    description?: boolean;
    content?: boolean;
    tooltip?: boolean;
    icon?: boolean;
    label?: boolean;
    placeholder?: boolean;
  };
  needsTrigger?: boolean;
  triggerText?: string;
  customProps?: Record<string, any>;
  showStateLabel?: boolean;
  layoutDescription?: string;
  notes?: string;
  demoContent?: (value: any, setValue: (val: any) => void) => ReactNode;
}

export function getCSSFamilies(): Array<{
  id: CSSFamily | 'all';
  label: string;
}> {
  const families = new Set<CSSFamily>();
  COMPONENT_CONFIGS.forEach((config) => {
    families.add(config.cssFamily);
  });

  const labels: Record<CSSFamily, string> = {
    surface: 'Card-based',
    floating: 'Floating',
    interactive: 'Interactive',
    layout: 'Layout',
    input: 'Input',
    other: 'Others',
  };

  const order: CSSFamily[] = [
    'layout',
    'surface',
    'floating',
    'interactive',
    'input',
    'other',
  ];

  return [
    { id: 'all', label: 'All' },
    ...order
      .filter((id) => families.has(id))
      .map((id) => ({ id, label: labels[id] || id })),
  ];
}

