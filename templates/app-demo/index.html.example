<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Meta tags -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DoNotDev Demo</title>

  <!-- Fonts: Inter, Space Grotesk, Playfair, Roboto from @donotdev/ui/dndev.css (bundled). -->

  <!-- ✅ CRITICAL CSS: ECG waveform loader -->
  <style>
    /* Critical above-the-fold styles */
    html, body {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      background: #ffffff;
      color: #000000;
    }
    @media (prefers-color-scheme: dark) {
      body {
        background: #000000;
        color: #ffffff;
      }
    }
    /* Critical shell loader styles - pure CSS, instant render */
    #shell-loader {
      position: fixed;
      inset: 0;
      background: #000000;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      opacity: 1;
      transition: opacity 0.3s ease-out;
      will-change: opacity;
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    #shell-loader.shell-loader--fading {
      opacity: 0;
      pointer-events: none;
    }
    .shell-loader__content {
      text-align: center;
      color: white;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      width: 100%;
      max-width: 500px;
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      line-height: 1.2;
    }
    .shell-loader__brand {
      display: block;
      font-size: clamp(3rem, 10vw, 5rem);
      font-weight: 800;
      letter-spacing: -0.05em;
      margin: 0 0 1rem 0;
      padding: 0;
      box-sizing: border-box;
    }
    /* ECG Waveform Animation */
    .shell-loader__dots {
      display: block;
      width: 300px;
      height: 60px;
      margin: 0 auto;
      padding: 0;
      box-sizing: border-box;
    }
    .shell-loader__dots svg {
      width: 100%;
      height: 100%;
      display: block;
    }
    .shell-loader__dots path {
      stroke: #667eea;
      stroke-width: 3;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 400;
      stroke-dashoffset: 400;
      animation: ecg-draw 2s linear infinite;
    }
    @keyframes ecg-draw {
      0% {
        stroke-dashoffset: 400;
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      70% {
        stroke-dashoffset: 0;
        opacity: 1;
      }
      90%, 100% {
        stroke-dashoffset: 0;
        opacity: 0;
      }
    }
  </style>

  <!-- ✅ THEME DETECTION: Force dark on first visit, remember user choice -->
  <script>
    (function () {
      'use strict';

      function getInitialTheme() {
        try {
          var saved = localStorage.getItem('dndev-theme');
          if (saved) {
            return saved;
          }
          return 'dark';
        } catch (e) {
          return 'dark';
        }
      }

      var theme = getInitialTheme();
      document.documentElement.className = theme;
    })();
  </script>
</head>

<body>
  <!-- ✅ SHELL LOADER: Branded loading experience before React loads -->
  <div id="shell-loader">
    <div class="shell-loader__content">
      <span class="shell-loader__brand">DoNotDev</span>
      <span class="shell-loader__dots">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 60" preserveAspectRatio="xMidYMid meet">
          <path d="M0,30 L100,30 L110,20 L120,30 L130,30 L140,5 L150,55 L160,30 L175,30 L190,20 L205,30 L300,30" />
        </svg>
      </span>
    </div>
  </div>

  <!-- React mounts here -->
  <div id="root"></div>

  <script type="module" src="/src/main.tsx"></script>
</body>

</html>
