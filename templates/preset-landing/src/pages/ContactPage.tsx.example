/**
 * @fileoverview Contact Page
 *
 * Contact form and information for {{appName}}.
 * Form submission is a placeholder - wire up to your backend.
 */

import { type FormEvent, useCallback, useState } from 'react';

import {
  Mail,
  MapPin,
  Phone,
  Send,
  MessageSquare,
} from 'lucide-react';

import {
  HeroSection,
  Section,
  Card,
  Grid,
  Stack,
  Text,
  Button,
  Input,
  Textarea,
  Alert,
} from '@donotdev/components';
import type { PageMeta } from '@donotdev/core';
import { useTranslation } from '@donotdev/core';
import { PageContainer } from '@donotdev/ui';

export const NAMESPACE = 'contact';

export const meta: PageMeta = {
  namespace: NAMESPACE,
  icon: <MessageSquare />,
};

export default function ContactPage() {
  const { t } = useTranslation(NAMESPACE);
  const [submitted, setSubmitted] = useState(false);

  const handleSubmit = useCallback((e: FormEvent) => {
    e.preventDefault();
    // TODO: Wire to your backend endpoint
    setSubmitted(true);
  }, []);

  return (
    <PageContainer variant="standard">
      {/* ================================================================ */}
      {/* HERO                                                             */}
      {/* ================================================================ */}

      <HeroSection
        title={t('hero.title', 'Let\'s talk')}
        subtitle={t(
          'hero.subtitle',
          'Have a question, feedback, or want to explore how {{appName}} can help your team? We would love to hear from you.'
        )}
        variant="accent"
      />

      {/* ================================================================ */}
      {/* CONTACT FORM + INFO                                              */}
      {/* ================================================================ */}

      <Section tone="ghost">
        <Grid cols={[1, 1, 2, 2]} gap="large">
          {/* --- Form --- */}
          <Card
            title={t('form.title', 'Send us a message')}
            content={
              submitted ? (
                <Alert
                  variant="success"
                  title={t('form.success.title', 'Message sent')}
                  description={t(
                    'form.success.desc',
                    'Thank you for reaching out. We will get back to you within 24 hours.'
                  )}
                />
              ) : (
                <Stack gap="medium">
                  <Input
                    label={t('form.name.label', 'Your name')}
                    placeholder={t('form.name.placeholder', 'Jane Doe')}
                  />
                  <Input
                    icon={<Mail />}
                    label={t('form.email.label', 'Email address')}
                    placeholder={t('form.email.placeholder', 'jane@company.com')}
                  />
                  <Input
                    label={t('form.subject.label', 'Subject')}
                    placeholder={t('form.subject.placeholder', 'How can we help?')}
                  />
                  <Textarea
                    label={t('form.message.label', 'Message')}
                    placeholder={t(
                      'form.message.placeholder',
                      'Tell us about your project or question...'
                    )}
                  />
                  <Button
                    variant="primary"
                    icon={<Send />}
                    onClick={handleSubmit}
                  >
                    {t('form.submit', 'Send Message')}
                  </Button>
                </Stack>
              )
            }
            elevated
          />

          {/* --- Contact Info --- */}
          <Stack gap="large">
            <Text as="h3" level="h3">
              {t('info.title', 'Other ways to reach us')}
            </Text>
            <Text level="body" variant="muted">
              {t(
                'info.subtitle',
                'Prefer a different channel? We are available through any of the options below.'
              )}
            </Text>

            <Stack gap="medium">
              <Card
                icon={<Mail />}
                title={t('info.email.title', 'Email')}
                content={t('info.email.value', 'hello@{{appShortName}}.dev')}
              />
              <Card
                icon={<Phone />}
                title={t('info.phone.title', 'Phone')}
                content={t('info.phone.value', '+1 (555) 123-4567')}
              />
              <Card
                icon={<MapPin />}
                title={t('info.address.title', 'Office')}
                content={t(
                  'info.address.value',
                  '123 Innovation Drive, San Francisco, CA 94107'
                )}
              />
            </Stack>
          </Stack>
        </Grid>
      </Section>

      {/* ================================================================ */}
      {/* RESPONSE TIME                                                    */}
      {/* ================================================================ */}

      <Section tone="muted" textAlign="center">
        <Stack align="center" gap="medium">
          <Text as="h3" level="h3">
            {t('response.title', 'What to expect')}
          </Text>
          <Grid cols={[1, 3, 3, 3]} gap="medium">
            <Card
              title={t('response.time.title', 'Under 24h')}
              content={t('response.time.desc', 'Average response time for all inquiries')}
              elevated
            />
            <Card
              title={t('response.support.title', 'Priority Support')}
              content={t(
                'response.support.desc',
                'Pro and Enterprise plans get dedicated Slack channels'
              )}
              elevated
            />
            <Card
              title={t('response.docs.title', 'Self-serve')}
              content={t(
                'response.docs.desc',
                'Most answers are in our docs - check there first for instant help'
              )}
              elevated
            />
          </Grid>
        </Stack>
      </Section>
    </PageContainer>
  );
}
