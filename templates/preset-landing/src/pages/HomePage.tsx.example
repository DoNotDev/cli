            },
            {
              title: t('roadmap.step2.title', 'Model'),
              description: t(
                'roadmap.step2.desc',
                'Define your data entities, relationships, and business rules. The framework generates types, validation, and API endpoints.'
              ),
            },
            {
              title: t('roadmap.step3.title', 'Compose'),
              description: t(
                'roadmap.step3.desc',
                'Build your UI by assembling production-grade components. Responsive, accessible, and themed by default.'
