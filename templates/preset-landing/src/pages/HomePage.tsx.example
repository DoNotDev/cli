/**
 * @fileoverview Landing Home Page
 *
 * Main marketing landing page for {{appName}}.
 * Multi-section single-page layout with hero, features, social proof, and CTA.
 */

import {
  Rocket,
  Shield,
  Zap,
  Globe,
  BarChart3,
  Layers,
  Home,
  Star,
  Building2,
  Sparkles,
} from 'lucide-react';

import {
  HeroSection,
  Section,
  Card,
  Grid,
  Stack,
  Text,
  CallToAction,
  Accordion,
  Marquee,
  SplitReveal,
  Carousel,
  Roadmap,
  Badge,
} from '@donotdev/components';
import { FeatureCard } from '@donotdev/ui';
import type { PageMeta } from '@donotdev/core';
import { useTranslation } from '@donotdev/core';
import { PageContainer } from '@donotdev/ui';

export const NAMESPACE = 'home';

export const meta: PageMeta = {
  namespace: NAMESPACE,
  icon: <Home />,
  route: '/',
};

export default function HomePage() {
  const { t } = useTranslation(NAMESPACE);

  return (
    <PageContainer variant="full">
      {/* ================================================================ */}
      {/* HERO                                                             */}
      {/* ================================================================ */}

      <HeroSection
        badge={t('hero.badge', 'Now available - Start building today')}
        title={t('hero.title', 'Build remarkable products with {{appName}}')}
        subtitle={t(
          'hero.subtitle',
          'The platform that helps teams ship faster, iterate smarter, and scale without compromise. From idea to production in record time.'
        )}
        variant="primary"
      />

      {/* ================================================================ */}
      {/* TRUSTED BY                                                       */}
      {/* ================================================================ */}

      <Section tone="ghost" textAlign="center">
        <Stack align="center" gap="medium">
          <Text level="caption" variant="muted">
            {t('trusted.label', 'Trusted by forward-thinking teams worldwide')}
          </Text>
          <Marquee
            items={[
              { name: 'Acme Corp' },
              { name: 'Globex' },
              { name: 'Initech' },
              { name: 'Umbrella' },
              { name: 'Cyberdyne' },
              { name: 'Stark Industries' },
              { name: 'Wayne Enterprises' },
              { name: 'Oscorp' },
            ]}
            renderItem={(item) => (
              <Badge variant="outline" tooltip={item.name}>
                <Stack direction="row" align="center" gap="tight">
                  <Building2 />
