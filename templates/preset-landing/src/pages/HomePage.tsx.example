      >
        <Grid cols={[1, 2, 2, 3]} gap="large">
          <FeatureCard
            icon={<Zap />}
            title={t('features.speed.title', 'Lightning Fast')}
            subtitle={t(
              'features.speed.subtitle',
              'Optimized for performance at every layer. Sub-second load times out of the box.'
            )}
          />
          <FeatureCard
            icon={<Shield />}
            title={t('features.security.title', 'Enterprise Security')}
            subtitle={t(
              'features.security.subtitle',
              'Built-in encryption, role-based access, and compliance tooling from day one.'
