                    {item.name}
                  </Text>
                </Stack>
              </Badge>
            )}
            speed={30}
            pauseOnHover
            gap="large"
          />
        </Stack>
      </Section>

      {/* ================================================================ */}
      {/* FEATURES                                                         */}
      {/* ================================================================ */}

      <Section
        title={t('features.title', 'Everything you need to succeed')}
