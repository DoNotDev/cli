/**
 * {{APP_NAME}} entity update
 * Wraps the framework function with {{APP_NAME}}-specific configuration
 */
export default async function handler(
  req: NextApiRequest,
  res: NextApiResponse
) {
  return frameworkUpdateEntity(req, res);
}
