/**
 * {{APP_NAME}} payment success processing
 * Wraps the framework function with {{APP_NAME}}-specific configuration
 */
export default async function handler(
  req: NextApiRequest,
  res: NextApiResponse
) {
  return frameworkProcessPaymentSuccess(req, res);
}
