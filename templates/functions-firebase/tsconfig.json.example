{
  "extends": "../../../tsconfig.functions.json",
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "outDir": "./lib",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "**/*.test.ts"]
}
